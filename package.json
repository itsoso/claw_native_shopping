{
  "name": "claw-native-commerce",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "dev": "pnpm --filter @claw/browser-extension dev",
    "build": "pnpm --filter @claw/browser-extension build",
    "dev:web": "pnpm --dir apps/web dev",
    "build:web": "pnpm --dir apps/web build",
    "preview:web": "pnpm --dir apps/web exec vite preview --host 127.0.0.1 --port 4174 --strictPort",
    "preview:web:e2e": "pnpm build:web && pnpm --dir apps/web exec vite preview --host 127.0.0.1 --port 4274 --strictPort",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "verify": "bash scripts/verify.sh",
    "dev:api": "tsx apps/api/src/server.ts",
    "dev:seller-sim": "tsx apps/seller-sim/src/server.ts",
    "start:api": "tsx apps/api/src/server.ts",
    "start:seller-sim": "tsx apps/seller-sim/src/server.ts",
    "generate:deck:fundraising": "node scripts/generate-fundraising-deck.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.13.14",
    "eslint": "^9.23.0",
    "jsdom": "^29.0.1",
    "linkedom": "^0.18.12",
    "pptxgenjs": "^4.0.1",
    "prettier": "^3.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsx": "^4.20.6",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  },
  "dependencies": {
    "fastify": "^5.3.0",
    "zod": "^3.24.2"
  }
}
